# ── Postgres: Prefect metadata ──────────────────────────────────────────────
POSTGRES_PREFECT_USER=prefect
POSTGRES_PREFECT_PASSWORD=prefect
POSTGRES_PREFECT_DB=prefect

# ── Postgres: Weather data warehouse ────────────────────────────────────────
POSTGRES_WEATHER_USER=weather
POSTGRES_WEATHER_PASSWORD=weather
POSTGRES_WEATHER_DB=weather

# ── Prefect ──────────────────────────────────────────────────────────────────
PREFECT_API_URL=http://prefect-server:4200/api

# ── Services ─────────────────────────────────────────────────────────────────
API_URL=http://api:8000

# ── Alembic / flows DB connection ────────────────────────────────────────────
DATABASE_URL=postgresql://weather:weather@postgres-weather:5432/weather
